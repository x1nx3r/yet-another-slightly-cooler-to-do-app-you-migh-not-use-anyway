{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yet-another-slighty-cooler-to-do-list-app",
  "version": "0.1.0",
  "identifier": "com.x1nx3r.yet-another-slighty-cooler-to-do-list-app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "dock",
        "title": "Task Dock",
        "width": 1366,
        "height": 30,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      },
      {
        "label": "settings",
        "title": "Task Settings",
        "width": 280,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false
      },
      {
        "label": "keystrokes",
        "title": "Keystrokes",
        "width": 600,
        "height": 30,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      },
      {
        "label": "music",
        "title": "Music Widget",
        "width": 400,
        "height": 30,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}